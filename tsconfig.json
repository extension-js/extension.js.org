{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ESNext"],
    "allowJs": true,
    "noEmit": true,
    "module": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "baseUrl": "./"
  },
  "mdx": {
    "checkMdx": true
  },
  "include": ["docs", "__tests__", "scripts"]
}
