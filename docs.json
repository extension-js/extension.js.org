  "redirects": [
    {"source": "/", "destination": "/welcome"},
    {"source": "/docs", "destination": "/welcome"},
    {"source": "/docs/welcome", "destination": "/welcome"},
    {"source": "/docs/:slug*", "destination": "/:slug*"},
    {"source": "/docs/en/:slug*", "destination": "/:slug*"}
  ]
