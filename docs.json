      "discord": "https://discord.gg/v9h2RgeTSN"
    }
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-NJD6VVD4"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "Extension.js",
      "og:title": "The cross-browser extension framework",
      "og:url": "https://extension.js.org",
      "og:image": "https://github.com/user-attachments/assets/410bc1bc-a2dd-4c89-97e7-dffc18a0d035",
