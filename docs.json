{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Extension.js",
  "description": "Build browser extensions for Chrome, Edge, and Firefox with one modern workflow. Extension.js handles manifest compilation, browser-specific output, reload behavior, and packaging so you can focus on product features.",
  "colors": {
    "primary": "#0e62f7",
    "light": "#60a5fa",
    "dark": "#0e62f7"
  },
  "appearance": {
    "default": "dark"
  },
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-dark.png"
  },
  "favicon": "/favicon.png",
  "banner": {
    "content": "🎉 [Extension.js v3.0.0 is here](/announcing-3-0-0) — faster builds, Firefox MV3, and first-class TypeScript.",
    "dismissible": true
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "cursor", "vscode", "mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Introduction",
            "icon": "sparkles",
            "pages": ["docs/welcome", "docs/ai-access"]
          },
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
