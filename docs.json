    "primary": "#0e62f7",
    "light": "#60a5fa",
    "dark": "#0e62f7"
  },
  "appearance": {
    "default": "dark"
  },
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-dark.png"
  },
  "favicon": "/favicon.png",
  "banner": {
    "content": "🎉 [Extension.js v3 is here](/blog/announcing-3-0-0). Faster builds, Firefox MV3, and first-class TypeScript.",
    "dismissible": true
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode",
      "mcp"
    ]
