          "icon": "discord"
        },
        {
          "anchor": "X",
          "href": "https://twitter.com/extensionjs",
          "icon": "x-twitter"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Edit on GitHub",
        "href": "https://github.com/extension-js/extension.js.org/tree/main/docs"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/extension-js/extension.js"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/extension-js/extension.js",
