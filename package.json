{
  "private": true,
  "name": "extension.js.org",
  "version": "1.0.0",
  "type": "module",
  "description": "The 🧩 Extension official documentation website.",
  "scripts": {
    "dev": "mint dev",
    "broken-links": "mint broken-links",
    "validate": "mint validate",
    "sort-projects-words": "node ./sortProjectWords.cjs",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "lint:ci": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json,yml,yaml}\"",
    "format:ci": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json,yml,yaml}\"",
    "check:spell": "npx cspell",
    "check:case": "npx case-police docs/**/*.{md,mdx}",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run lint && pnpm run format && pnpm run check:spell",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci && pnpm run check:spell"
  },
  "author": "Cezar Augusto",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "case-police": "2.2.1",
    "cspell": "^10.0.0",
    "cspell-ban-words": "0.0.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-turbo": "^2.9.6",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
