{
  "private": true,
  "name": "extension.js.org",
  "version": "1.0.0",
  "type": "module",
  "description": "The 🧩 Extension official documentation website.",
  "scripts": {
    "postbuild": "node ./postinstall-scripts.cjs",
    "dev": "rspress dev",
    "build": "rspress build",
    "preview": "rspress preview",
    "sort-projects-words": "node ./sortProjectWords.cjs",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "lint:ci": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json,yml,yaml}\"",
    "format:ci": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json,yml,yaml}\"",
    "check:spell": "npx cspell",
    "check:case": "npx case-police docs/**/*.{md,mdx}",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run lint && pnpm run format && pnpm run check:spell",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci && pnpm run check:spell"
  },
  "author": "Cezar Augusto",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rstack-dev/doc-ui": "^1.12.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-gist": "^1.2.4",
    "react-icon-cloud": "^4.1.7",
    "react-tweet": "^3.3.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rspress/core": "2.0.9",
    "@rspress/plugin-sitemap": "2.0.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "case-police": "2.2.1",
    "cspell": "^10.0.0",
    "cspell-ban-words": "0.0.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-turbo": "^2.9.6",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "rsbuild-plugin-google-analytics": "1.0.5",
    "rsbuild-plugin-open-graph": "1.1.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
